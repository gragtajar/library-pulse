{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "htmlWhitespaceSensitivity": "css",
  "overrides": [
    {
      "files": ["*.md"],
      "options": { "proseWrap": "preserve", "printWidth": 100 }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": { "singleQuote": false, "tabWidth": 2 }
    },
    {
      "files": ["*.sql"],
      "options": { "printWidth": 120 }
    }
  ]
}
