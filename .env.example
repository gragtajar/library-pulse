# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Encryption (generate: openssl rand -hex 32) ──
ENCRYPTION_KEY=64-char-hex-string-here

# ── Slack OAuth App ──
SLACK_CLIENT_ID=123456789.123456789
SLACK_CLIENT_SECRET=abcdef1234567890
SLACK_SIGNING_SECRET=abcdef1234567890

# ── Figma OAuth App (required) ──
# Each user authorizes their own file webhook, so the backend exchanges OAuth
# codes via this app. Create one at https://www.figma.com/developers/apps with:
#   • redirect URL:  <PUBLIC_URL>/api/auth/figma-callback
#   • scope:         webhooks:write   (and a file-read scope)
FIGMA_CLIENT_ID=your-figma-client-id
FIGMA_CLIENT_SECRET=your-figma-client-secret

# Note: FIGMA_ADMIN_TOKEN / FIGMA_TEAM_ID are no longer used (the old
# single-team model). Safe to delete from Vercel if present.

# ── Public URL (your Vercel deployment) ──
PUBLIC_URL=https://library-pulse.vercel.app
